FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/ cmd/
COPY internal/ internal/
RUN CGO_ENABLED=0 go build -o /bidder ./cmd/bidder

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /bidder /usr/local/bin/bidder
EXPOSE 8180
CMD ["bidder"]
